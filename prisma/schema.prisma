// Esquema de base de datos para Oral-7
// Plataforma educativa para "Producción e interacción oral en español" - Nivel C1

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// MODELOS DE AUTENTICACIÓN Y USUARIOS
// ============================================

model User {
  id                String               @id @default(dbgenerated("(gen_random_uuid())::text"))
  email             String               @unique
  name              String
  password          String?
  image             String?
  role              UserRole             @default(STUDENT)
  level             String?              @default("C2")
  motivation        String?
  active            Int?                 @default(1)
  twoFactorEnabled  Boolean              @default(false)
  twoFactorSecret   String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  last_login        DateTime?            @db.Timestamp(6)
  created_at        DateTime?            @default(now()) @db.Timestamp(6)
  updated_at        DateTime?            @default(now()) @db.Timestamp(6)

  // Relaciones
  attendances       Attendance[]
  debateVotes       DebateVote[]
  submissions       Submission[]
  checklistItems    UserChecklistItem[]
  progress          UserProgress[]
  user_registrations user_registrations[]

  @@index([email])
  @@index([role])
  @@map("users")
}

enum UserRole {
  ADMIN     // Profesor
  STUDENT   // Estudiante
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  usedAt    DateTime?

  @@index([email])
  @@index([token])
  @@map("password_reset_tokens")
}

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// MODELOS DE SESIONES Y CONTENIDO
// ============================================

model Session {
  id              String        @id @default(cuid())
  sessionNumber   Int           @unique
  date            DateTime
  title           String
  subtitle        String?
  blockNumber     Int
  blockTitle      String
  isExamDay       Boolean       @default(false)
  examType        ExamType?

  objectives      Json
  timing          Json
  dynamics        Json
  grammarContent  Json?
  vocabularyContent Json?
  modeAContent    Json?
  modeBContent    Json?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  attendances     Attendance[]
  tasks           Task[]
  checklistItems  ChecklistItem[]
  resources       Resource[]
  progress        UserProgress[]

  @@index([sessionNumber])
  @@map("sessions")
}

enum ExamType {
  PARTIAL
  FINAL
}

// ============================================
// MODELO DE TAREAS INTERACTIVAS
// ============================================

model Task {
  id          String      @id @default(cuid())
  sessionId   String
  title       String
  description String?
  type        TaskType
  content     Json
  order       Int
  isModeBOnly Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  submissions Submission[]
  session     Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

enum TaskType {
  MULTIPLE_CHOICE
  FILL_BLANKS
  DRAG_DROP
  MATCHING
  ORDERING
  FREE_TEXT
  AUDIO_RECORDING
  VIDEO_RECORDING
  DOCUMENT_UPLOAD
}

// ============================================
// MODELO DE ENTREGAS/SUBMISSIONS
// ============================================

model Submission {
  id             String    @id @default(cuid())
  userId         String
  taskId         String
  content        Json
  score          Float?
  feedback       String?
  user_id        Int?
  session_id     Int?
  activity_id    String?
  activity_title String?
  word_count     Int?      @default(0)
  status         String?   @default("pending")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  updated_at     DateTime? @default(now()) @db.Timestamp(6)

  task           Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId])
  @@index([session_id], map: "idx_submissions_session")
  @@index([status], map: "idx_submissions_status")
  @@index([user_id], map: "idx_submissions_user")
  @@map("submissions")
}

// ============================================
// MODELO DE CHECKLIST DE AUTOEVALUACIÓN
// ============================================

model ChecklistItem {
  id        String              @id @default(cuid())
  sessionId String
  text      String
  order     Int
  session   Session             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userItems UserChecklistItem[]

  @@map("checklist_items")
}

model UserChecklistItem {
  id              String        @id @default(cuid())
  userId          String
  checklistItemId String
  isCompleted     Boolean       @default(false)
  completedAt     DateTime?
  checklistItem   ChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, checklistItemId])
  @@map("user_checklist_items")
}

// ============================================
// MODELO DE RECURSOS DESCARGABLES
// ============================================

model Resource {
  id        String       @id @default(cuid())
  sessionId String
  title     String
  description String?
  type      ResourceType
  url       String
  order     Int
  createdAt DateTime     @default(now())
  session   Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("resources")
}

enum ResourceType {
  PDF
  AUDIO
  VIDEO
  LINK
  IMAGE
}

// ============================================
// MODELO DE ASISTENCIA
// ============================================

model Attendance {
  id           String           @id @default(cuid())
  userId       String
  sessionId    String
  registeredAt DateTime         @default(now())
  method       AttendanceMethod
  session      Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sessionId])
  @@index([sessionId])
  @@map("attendances")
}

enum AttendanceMethod {
  QR_SCAN
  MANUAL_CODE
  ADMIN
}

// ============================================
// MODELO DE CÓDIGOS QR DINÁMICOS
// ============================================

model QRCode {
  id        String   @id @default(cuid())
  code      String   @unique
  sessionId String
  expiresAt DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("qr_codes")
}

// ============================================
// MODELO DE PROGRESO DEL USUARIO
// ============================================

model UserProgress {
  id             String    @id @default(cuid())
  userId         String
  sessionId      String
  viewedAt       DateTime?
  timeSpent      Int       @default(0)
  lastAccess     DateTime  @default(now())
  modePreference String    @default("A")
  session        Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sessionId])
  @@map("user_progress")
}

// ============================================
// MODELO DE CONFIGURACIÓN GLOBAL
// ============================================

model Settings {
  id              String   @id @default("global")
  currentSession  Int      @default(1)
  courseStartDate DateTime
  courseEndDate   DateTime
  updatedAt       DateTime @updatedAt

  @@map("settings")
}

// ============================================
// MODELO DE VOTACIÓN DE DEBATES
// ============================================

model DebateTopic {
  id          String       @id @default(cuid())
  title       String
  description String
  category    String
  order       Int
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  votes       DebateVote[]

  @@map("debate_topics")
}

model DebateVote {
  id        String      @id @default(cuid())
  userId    String
  topicId   String
  rank      Int
  createdAt DateTime    @default(now())

  topic     DebateTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@index([userId])
  @@index([topicId])
  @@map("debate_votes")
}

// ============================================
// MODELOS ADICIONALES (LEGACY)
// ============================================

model course_sessions {
  id         Int       @id
  date       String
  day        String
  title      String
  theme      Int?
  workshop   Int?
  contents   String?
  created_at DateTime? @default(now()) @db.Timestamp(6)
}

model feedback {
  id            Int       @id @default(autoincrement())
  submission_id Int       @unique
  reviewer_id   String
  feedback_text String
  grade         String?
  annotations   String?
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  updated_at    DateTime? @default(now()) @db.Timestamp(6)

  @@index([submission_id], map: "idx_feedback_submission")
}

model messages {
  id           Int       @id @default(autoincrement())
  from_user_id String
  to_user_id   String
  subject      String
  content      String
  read         Int?      @default(0)
  parent_id    Int?
  created_at   DateTime? @default(now()) @db.Timestamp(6)

  @@index([to_user_id], map: "idx_messages_to")
}

model notifications {
  id         Int       @id @default(autoincrement())
  user_id    String
  type       String
  title      String
  message    String
  read       Int?      @default(0)
  created_at DateTime? @default(now()) @db.Timestamp(6)

  @@index([user_id], map: "idx_notifications_user")
}

model registration_codes {
  id                 String               @id
  code               String               @unique
  isActive           Boolean              @default(true)
  maxUses            Int                  @default(1)
  usedCount          Int                  @default(0)
  description        String?
  createdAt          DateTime             @default(now())
  expiresAt          DateTime?
  user_registrations user_registrations[]
}

model student_progress {
  id           Int       @id @default(autoincrement())
  user_id      String
  session_id   Int
  completed    Int?      @default(0)
  completed_at DateTime? @db.Timestamp(6)
  notes        String?

  @@unique([user_id, session_id])
  @@index([user_id], map: "idx_student_progress_user")
}

model user_registrations {
  id                 String             @id
  userId             String
  codeId             String
  usedAt             DateTime           @default(now())
  registration_codes registration_codes @relation(fields: [codeId], references: [id], onDelete: Cascade)
  users              User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([codeId, userId])
}
